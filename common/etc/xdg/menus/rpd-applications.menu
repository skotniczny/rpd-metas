<?xml version="1.0"?>

<Menu>

	<Name>Applications</Name>
	<Directory>rpd-applications.directory</Directory>

	<DefaultAppDirs/>
	<DefaultDirectoryDirs/>
	<DefaultMergeDirs/>

	<Menu>
