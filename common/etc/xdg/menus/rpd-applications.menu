	</Menu>

	<Menu>
		<Name>System</Name>
		<Directory>rpd-system-tools.directory</Directory>
		<Include>
			<Category>System</Category>
		</Include>
	</Menu>

	<Menu>
		<Name>Utility</Name>
		<Directory>rpd-utility.directory</Directory>
		<Include>
			<Category>Utility</Category>
		</Include>
	</Menu>

	<Menu>
		<Name>Help</Name>
		<Directory>rpd-help.directory</Directory>
