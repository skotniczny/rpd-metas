			<Category>Help</Category>
		</Include>
	</Menu>

	<Menu>
		<Name>Other</Name>
		<Directory>rpd-other.directory</Directory>
		<OnlyUnallocated/>
		<Include>
			<And>
			</And>
		</Include>
	</Menu>

	<Include>
		<Category>Applications</Category>
	</Include>

	<Layout>
		<Menuname>Development</Menuname>
		<Menuname>Education</Menuname>
		<Menuname>Science</Menuname>
		<Menuname>Office</Menuname>
		<Menuname>Network</Menuname>
		<Menuname>AudioVideo</Menuname>
		<Menuname>Graphics</Menuname>
		<Menuname>Game</Menuname>
		<Menuname>Other</Menuname>
		<Menuname>System</Menuname>
		<Menuname>Utility</Menuname>
		<Merge type="menus"/>
		<Separator/>
		<Menuname>Help</Menuname>
		<Separator/>
		<Menuname>Settings</Menuname>
		<Separator/>
		<Merge type="files"/>
		<Filename>gui-runcmd.desktop</Filename>
		<Separator/>
		<Filename>pishutdown.desktop</Filename>
	</Layout>

</Menu>
